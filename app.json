  },
  "homeyCommunityTopicId": 74195,
  "support": "https://github.com/complus-fi/com.go-e/issues",
  "drivers": [
    {
      "class": "evcharger",
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/go-eCharger_PRO/assets/images/small.png",
        "large": "/drivers/go-eCharger_PRO/assets/images/large.png",
        "xlarge": "/drivers/go-eCharger_PRO/assets/images/xlarge.png"
      },
      "discovery": "mdns_http_go-e",
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices",
          "navigation": {
            "next": "done"
          }
        },
        {
          "id": "done",
          "template": "done"
        }
      ],
      "capabilities": [
        "onoff",
        "meter_power",
        "meter_power.charged",
        "meter_power.discharged",
        "measure_power",
        "measure_voltage",
        "measure_voltage.output",
        "measure_current",
        "evcharger_charging",
        "evcharger_charging_state",
        "target_power",
        "target_power_mode"
      ],
      "capabilityOptions": {
        "measure_voltage.output": {
          "type": "number",
          "title": {
            "en": "Output Voltage"
          },
          "hint": {
            "en": "Currently delivered voltage in volts."
          },
          "getable": true,
          "setable": false,
          "units": {
            "en": "V"
          },
          "min": 0,
          "max": 500,
          "insights": true
        },
        "target_power": {
          "min": -11000,
          "max": 11000,
          "step": 230,
          "excludeMin": -1380,
          "excludeMax": 1380
        }
      },
      "energy": {
        "evCharger": true,
        "meterPowerImportedCapability": "meter_power.charged",
        "meterPowerExportedCapability": "meter_power.discharged"
      },
      "name": {
        "en": "PRO",
        "nl": "PRO",
        "de": "PRO",
        "fr": "PRO"
      },
      "id": "go-eCharger_PRO",
      "settings": [
        {
          "id": "address",
          "type": "group",
          "label": {
            "en": "Discovered device information."
          },
          "value": "0.0.0.0",
          "hint": {
            "en": "Discovered IP address of the device."
          },
          "children": [
            {
              "id": "version",
              "type": "label",
              "label": {
                "en": "Firmware"
              },
              "value": "",
              "hint": {
                "en": "Device firmware version."
              }
            },
            {
              "id": "type",
              "type": "label",
              "label": {
                "en": "Type"
              },
              "value": "",
              "hint": {
                "en": "Device type."
              }
            },
            {
              "id": "driver",
              "type": "label",
              "label": {
                "en": "Driver"
              },
              "value": "",
              "hint": {
                "en": "Driver used during pairing."
              }
            }
          ]
        }
      ]
    }
  ],
  "discovery": {
    "mdns_http_go-e": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "http",
        "protocol": "tcp"
      },
      "id": "{{txt.serial}}",
      "conditions": [
        [
          {
            "field": "txt.manufacturer",
            "match": {
              "type": "string",
              "value": "go-e"
            }
          },
          {
            "field": "txt.devicefamily",
            "match": {
              "type": "string",
              "value": "goecharger"
            }
          }
        ]
      ]
    }
  }
}