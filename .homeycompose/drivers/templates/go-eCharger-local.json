{
  "$extends": "go-eCharger",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices",
      "navigation": {
        "next": "done"
      }
    },
    {
      "id": "done",
      "template": "done"
    }
  ]
}