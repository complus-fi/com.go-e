{
  "type": "mdns-sd",
  "mdns-sd": {
    "name": "http",
    "protocol": "tcp"
  },
  "id": "{{txt.serial}}",
  "conditions": [
    [
      {
        "field": "txt.manufacturer",
        "match": {
          "type": "string",
          "value": "go-e"
        }
      },
      {
        "field": "txt.devicefamily",
        "match": {
          "type": "string",
          "value": "goecharger"
        }
      },
      {
        "field": "txt.devicetype",
        "match": {
          "type": "string",
          "value": "go-eCharger_Phoenix"
        }
      },
      {
        "field": "txt.devicesubtype",
        "match": {
          "type": "regex",
          "value": "^pro"
        }
      }
    ]
  ]
}
