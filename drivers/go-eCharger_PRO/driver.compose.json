{
  "name": {
    "en": "PRO",
    "nl": "PRO",
    "de": "PRO",
    "fr": "PRO"
  },
  "$extends": ["local"],
  "capabilities": [
    "onoff",
    "measure_power",
    "meter_power",
    "meter_power.session",
    "measure_voltage",
    "measure_voltage.output",
    "measure_current"
  ],
  "capabilityOptions": {
    "meter_power.session": {
      "type": "number",
      "title": {
        "en": "Energy Last Session"
      },
      "hint:": {
        "en": "Energy (kWh) delivered during last session. Reset automatically when a car is connected."
      },
      "getable": true,
      "setable": false,
      "units": {
        "en": "kWh"
      },
      "insights": true
    },
    "measure_voltage.output": {
      "type": "number",
      "title": {
        "en": "Output Voltage"
      },
      "hint": {
        "en": "Currently delivered voltage in volts."
      },
      "getable": true,
      "setable": false,
      "units": {
        "en": "V"
      },
      "min": 0,
      "max": 500,
      "insights": true
    }
  }
}
